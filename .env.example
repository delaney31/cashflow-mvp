# Copy to .env at repo root or per-app as needed (see README).

# --- API (apps/api) ---
PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_SEC=604800

# PostgreSQL (packages/db, Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cashflow_dev?schema=public

# Plaid (future)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# OpenAI (future)
# OPENAI_API_KEY=

# Mobile (Expo) — use EXPO_PUBLIC_ for values exposed to the client bundle
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
