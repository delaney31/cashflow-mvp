# Copy to `.env` at the repo root or merge into per-app `.env` files.
# Details: docs/ENVIRONMENT.md

# --- Database (Prisma: packages/db + apps/api) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cashflow_dev?schema=public
# Same as DATABASE_URL for local Postgres. On Neon: pooled `DATABASE_URL` + direct `DIRECT_URL` (see docs/ENVIRONMENT.md).
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/cashflow_dev?schema=public

# --- API (apps/api) — copy to apps/api/.env for local runs ---
# PORT=3000
# NODE_ENV=development
# JWT_SECRET=change-me-in-production-use-a-long-random-string
# JWT_EXPIRES_SEC=604800
# REDIS_URL=redis://localhost:6379
# WORKER_ENABLED=true
# JOB_SCHEDULER_ENABLED=true
# EXPO_ACCESS_TOKEN=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# --- Mobile (Expo) — only EXPO_PUBLIC_* is bundled; copy to apps/mobile/.env ---
# EXPO_PUBLIC_API_URL=http://localhost:3000/v1
# EXPO_PUBLIC_API_TOKEN=
