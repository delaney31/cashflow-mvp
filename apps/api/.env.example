PORT=3000
# Bind address (Render uses 0.0.0.0; default in code is 0.0.0.0)
# HOST=0.0.0.0
NODE_ENV=development

# JWT signing (min 32 chars recommended for HS256)
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_SEC=604800

# Required when Prisma is wired into the API
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cashflow_dev?schema=public
# For local dev, match DATABASE_URL. On Neon: use the direct (non-pooled) connection string for migrations.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/cashflow_dev?schema=public

# Background jobs (BullMQ + Redis). Omit REDIS_URL to disable queues (API still runs).
REDIS_URL=redis://localhost:6379
# Set false on API-only instances if workers run in another process
WORKER_ENABLED=true
# Set false to disable cron enqueue (e.g. worker-only deployment runs consumers only)
JOB_SCHEDULER_ENABLED=true

# Expo Push API (https://expo.dev/accounts/[account]/settings/access-tokens)
# Without this, critical alert pushes are logged but not sent
EXPO_ACCESS_TOKEN=

# OpenAI (AI Coach — optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Plaid (optional)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_WEBHOOK_URL=
